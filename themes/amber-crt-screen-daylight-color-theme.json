    "terminal.background": "#FDFAEC",
    "terminal.foreground": "#3A2410",
    "terminal.ansiBlack": "#3A2410",
    "terminal.ansiRed": "#8A2520",
    "terminal.ansiGreen": "#5A6B2E",
    "terminal.ansiYellow": "#8A6520",
