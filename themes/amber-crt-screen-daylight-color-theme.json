    "button.secondaryBackground": "#ECDAB6",
    "button.secondaryForeground": "#3A2410",
    "button.secondaryHoverBackground": "#E0CCA6",
    "list.activeSelectionBackground": "#F1D6BA",
    "list.activeSelectionForeground": "#8A2520",
