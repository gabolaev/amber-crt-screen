    "selection.background": "#B85A2044",
    "quickInput.background": "#F9F0D8",
    "quickInput.foreground": "#3A2410",
    "quickInputTitle.background": "#F3E7CC",
    "quickInputList.focusBackground": "#F1D6BA",
    "quickInputList.focusForeground": "#8A2520",
    "quickInputList.focusIconForeground": "#8A2520",
    "pickerGroup.foreground": "#B85A20",
    "pickerGroup.border": "#E0CCA6",
    "editorWidget.background": "#F9F0D8",
    "editorWidget.foreground": "#3A2410",
    "editorWidget.border": "#A89668",
    "editorSuggestWidget.background": "#F9F0D8",
    "editorSuggestWidget.foreground": "#3A2410",
    "editorSuggestWidget.selectedBackground": "#F1D6BA",
    "editorSuggestWidget.selectedForeground": "#8A2520",
    "editorSuggestWidget.highlightForeground": "#B85A20",
    "editorSuggestWidget.border": "#A89668",
    "editorHoverWidget.background": "#F9F0D8",
    "editorHoverWidget.border": "#A89668",
    "menu.background": "#F9F0D8",
    "menu.foreground": "#3A2410",
    "menu.selectionBackground": "#F1D6BA",
    "menu.selectionForeground": "#8A2520",
    "menu.selectionBorder": "#A89668",
    "menu.separatorBackground": "#E0CCA6",
    "menu.border": "#A89668",
    "menubar.selectionBackground": "#F1D6BA",
    "menubar.selectionForeground": "#8A2520",
    "menubar.selectionBorder": "#A89668"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A7A4A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#8A2520"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#5A4A30"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#5A6B2E"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#6E7E3A"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#7A3A50"
      }
    },
    {
      "scope": [
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#7A3A50"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#B85A20"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#8A6520"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#3A2410"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#3A5560",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.property"
      ],
      "settings": {
        "foreground": "#3A5560"
      }
    },
    {
      "scope": [
        "variable.language",
        "this",
        "super"
      ],
      "settings": {
        "foreground": "#A03020",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#8A2520"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4A7048"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#A03020",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#B85A20",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#8A6520",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#3A2410",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#5A6B2E"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#6E7E3A"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#8A2520"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#8A6520"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#3A5560",
        "fontStyle": "underline"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#8A6520",
    "interface": "#8A6520",
    "enum": "#8A6520",
    "enumMember": "#7A3A50",
    "function": "#B85A20",
    "method": "#B85A20",
    "property": "#3A5560",
    "variable": "#3A2410",
    "parameter": {
      "foreground": "#3A5560",
      "italic": true
    },
    "string": "#5A6B2E",
    "number": "#7A3A50",
    "boolean": "#7A3A50",
    "keyword": "#8A2520",
    "operator": "#5A4A30",
    "type": "#8A6520",
    "namespace": "#4A7048",
    "comment": {
      "foreground": "#8A7A4A",
      "italic": true
    }
  }
}
