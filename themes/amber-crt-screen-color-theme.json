    "quickInputTitle.background": "#2A1208",
    "quickInputList.focusBackground": "#3A1A14",
    "quickInputList.focusForeground": "#FE8019",
    "quickInputList.focusIconForeground": "#FE8019",
    "pickerGroup.foreground": "#FE8019",
    "pickerGroup.border": "#3A210C",
    "editorWidget.background": "#1A0C08",
    "editorWidget.foreground": "#E8C49C",
    "editorWidget.border": "#5A2218",
    "editorSuggestWidget.background": "#1A0C08",
    "editorSuggestWidget.foreground": "#E8C49C",
    "editorSuggestWidget.selectedBackground": "#3A1A14",
    "editorSuggestWidget.selectedForeground": "#FE8019",
    "editorSuggestWidget.highlightForeground": "#E8B040",
    "editorSuggestWidget.border": "#5A2218",
    "editorHoverWidget.background": "#1A0C08",
    "editorHoverWidget.border": "#5A2218",
    "menu.background": "#1A0C08",
    "menu.foreground": "#E8C49C",
    "menu.selectionBackground": "#3A1A14",
    "menu.selectionForeground": "#FE8019",
    "menu.selectionBorder": "#5A2218",
    "menu.separatorBackground": "#3A210C",
    "menu.border": "#5A2218",
    "menubar.selectionBackground": "#3A1A14",
    "menubar.selectionForeground": "#FE8019",
    "menubar.selectionBorder": "#5A2218"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A6B4E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#CC4133"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#BDAE93"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#7A9080"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#8FA898"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#D3869B"
      }
    },
    {
      "scope": [
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#D3869B"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#FE8019"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#E8B040"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#E8C49C"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#83A598",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.property"
      ],
      "settings": {
        "foreground": "#83A598"
      }
    },
    {
      "scope": [
        "variable.language",
        "this",
        "super"
      ],
      "settings": {
        "foreground": "#FB4934",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#CC4133"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#8EC07C"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FB4934",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#FE8019",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E8B040",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#E8C49C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#7A9080"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#9AAA54"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#CC4133"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#E8B040"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#83A598",
        "fontStyle": "underline"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#E8B040",
    "interface": "#E8B040",
    "enum": "#E8B040",
    "enumMember": "#D3869B",
    "function": "#FE8019",
    "method": "#FE8019",
    "property": "#83A598",
    "variable": "#E8C49C",
    "parameter": {
      "foreground": "#83A598",
      "italic": true
    },
    "string": "#7A9080",
    "number": "#D3869B",
    "boolean": "#D3869B",
    "keyword": "#CC4133",
    "operator": "#BDAE93",
    "type": "#E8B040",
    "namespace": "#8EC07C",
    "comment": {
      "foreground": "#7A6B4E",
      "italic": true
    }
  }
}
