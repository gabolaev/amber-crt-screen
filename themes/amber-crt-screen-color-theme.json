    "button.secondaryHoverBackground": "#3A1A06",
    "list.activeSelectionBackground": "#2A1404",
    "list.activeSelectionForeground": "#E8B040",
    "list.inactiveSelectionBackground": "#1F1208",
    "list.inactiveSelectionForeground": "#E8C49C",
    "list.hoverBackground": "#3A1A06",
    "list.hoverForeground": "#FE8019",
    "list.focusOutline": "#FE8019",
    "list.highlightForeground": "#E8B040",
    "list.warningForeground": "#E8B040",
    "list.errorForeground": "#CC4133",
    "scrollbar.shadow": "#00000088",
    "scrollbarSlider.background": "#7A6B4E33",
    "scrollbarSlider.hoverBackground": "#928374AA",
    "scrollbarSlider.activeBackground": "#FE8019AA",
    "minimap.background": "#0E0905",
    "minimap.selectionHighlight": "#FE801933",
    "minimap.errorHighlight": "#CC4133AA",
    "minimap.warningHighlight": "#E8B040AA",
    "minimap.findMatchHighlight": "#FE801988",
    "minimapSlider.background": "#7A6B4E33",
    "minimapSlider.hoverBackground": "#928374AA",
    "minimapSlider.activeBackground": "#FE8019AA",
    "errorForeground": "#CC4133",
