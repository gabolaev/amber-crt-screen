    "pickerGroup.border": "#2A1408",
    "editorWidget.background": "#000000",
    "editorWidget.foreground": "#FF9038",
    "editorWidget.border": "#5A2008",
    "editorSuggestWidget.background": "#000000",
    "editorSuggestWidget.foreground": "#FF9038",
    "editorSuggestWidget.selectedBackground": "#2A1408",
    "editorSuggestWidget.selectedForeground": "#FE8019",
    "editorSuggestWidget.highlightForeground": "#FFA020",
    "editorSuggestWidget.border": "#5A2008",
    "editorHoverWidget.background": "#000000",
    "editorHoverWidget.border": "#5A2008",
    "menu.background": "#000000",
    "menu.foreground": "#FF9038",
    "menu.selectionBackground": "#2A1408",
    "menu.selectionForeground": "#FE8019",
    "menu.selectionBorder": "#5A2008",
    "menu.separatorBackground": "#2A1408",
    "menu.border": "#5A2008",
    "menubar.selectionBackground": "#2A1408",
    "menubar.selectionForeground": "#FE8019",
    "menubar.selectionBorder": "#5A2008"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6A2A08",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#FE8019"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#A04810"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#E06810"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#F07818"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#FFA020"
      }
    },
    {
      "scope": [
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFA020"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#FFA020"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#FFB840"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#FF9038"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#E06810",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.property"
      ],
      "settings": {
        "foreground": "#C85008"
      }
    },
    {
      "scope": [
        "variable.language",
        "this",
        "super"
      ],
      "settings": {
        "foreground": "#FF6010",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FE8019"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#F07818"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF4500",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#FE8019",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FFA020",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#FF9038",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#E06810"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#FFB840"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#8A3808"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFA020"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#FFA020",
        "fontStyle": "underline"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#FFB840",
    "interface": "#FFB840",
    "enum": "#FFB840",
    "enumMember": "#FFA020",
    "function": "#FFA020",
    "method": "#FFA020",
    "property": "#C85008",
    "variable": "#FF9038",
    "parameter": {
      "foreground": "#E06810",
      "italic": true
    },
    "string": "#E06810",
    "number": "#FFA020",
    "boolean": "#FFA020",
    "keyword": "#FE8019",
    "operator": "#A04810",
    "type": "#FFB840",
    "namespace": "#F07818",
    "comment": {
      "foreground": "#6A2A08",
      "italic": true
    }
  }
}
