    "button.hoverBackground": "#D85808",
    "button.secondaryBackground": "#1A0A02",
    "button.secondaryForeground": "#FF9038",
    "button.secondaryHoverBackground": "#2A1408",
    "list.activeSelectionBackground": "#2A1408",
    "list.activeSelectionForeground": "#FFA020",
    "list.inactiveSelectionBackground": "#1A0A02",
    "list.inactiveSelectionForeground": "#FF9038",
    "list.hoverBackground": "#1A0A02",
    "list.hoverForeground": "#FE8019",
    "list.focusOutline": "#FE8019",
    "list.highlightForeground": "#FFA020",
    "list.warningForeground": "#FFA020",
    "list.errorForeground": "#FF4500",
    "scrollbar.shadow": "#00000088",
    "scrollbarSlider.background": "#6A2A0833",
    "scrollbarSlider.hoverBackground": "#A04810AA",
    "scrollbarSlider.activeBackground": "#FE8019AA",
    "minimap.background": "#000000",
    "minimap.selectionHighlight": "#FE801933",
    "minimap.errorHighlight": "#FF4500AA",
    "minimap.warningHighlight": "#FFA020AA",
    "minimap.findMatchHighlight": "#FE801988",
    "minimapSlider.background": "#6A2A0833",
    "minimapSlider.hoverBackground": "#A04810AA",
    "minimapSlider.activeBackground": "#FE8019AA",
